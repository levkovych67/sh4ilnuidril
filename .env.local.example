# WayForPay (кабінет merchant)
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_MERCHANT_DOMAIN=isusneisus.com
WAYFORPAY_SECRET_KEY=

# Nova Poshta API
NOVAPOSHTA_API_KEY=

# Telegram (бот + чат менеджерів)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Публічний URL сайту
